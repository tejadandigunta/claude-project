{
  "permissions": {
    "allow": [
      "Bash(python3 -m pytest:*)",
      "Bash(python3 -m src.wordcount:*)"
    ]
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/check-python.sh"
          }
        ]
      }
    ]
  }
}
